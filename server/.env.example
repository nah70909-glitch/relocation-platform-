# ============================================================
# SERVER ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control!
# ============================================================

# Server port (default: 5000)
PORT=5000

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Connect your application
# Example: mongodb+srv://username:password@cluster.mongodb.net/relocity
MONGO_URI=

# JWT secret key — used to sign authentication tokens
# In production, use a long random string
JWT_SECRET=relocity-secret-key-change-in-production

# Frontend URL — for CORS configuration
CLIENT_URL=http://localhost:3000

# Node environment
NODE_ENV=development
